{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug Backtest",
      "cargo": {
        "args": ["build", "--bin=backtest"],
        "filter": {
          "name": "backtest",
          "kind": "bin"
        }
      },
      "args": [
        "--ticker", "AAPL",
        "--start", "2024-01-15",
        "--end", "2024-01-25",
        "--max-positions", "1",
        "-v", "2"
      ],
      "cwd": "${workspaceFolder}"
    }
  ]
}
